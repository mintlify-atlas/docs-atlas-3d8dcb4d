{
  "projectType": "api-service",
  "projectName": "FalconAlert API",
  "projectDescription": "A NestJS-based backend API for fraud reporting and moderation with real-time notifications.",
  "theme": "aspen",
  "primaryColor": "#DC2626",
  "lightColor": "#F87171",
  "darkColor": "#991B1B",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/reports", "concepts/users", "concepts/moderation"]
          },
          {
            "group": "Guides",
            "pages": ["guides/setup", "guides/database", "guides/file-uploads", "guides/websockets"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api/auth/login", "api/auth/refresh", "api/auth/verify"]
          },
          {
            "group": "Users",
            "pages": ["api/users/register", "api/users/profile", "api/users/update", "api/users/settings"]
          },
          {
            "group": "Reports",
            "pages": ["api/reports/list", "api/reports/create", "api/reports/update", "api/reports/delete"]
          },
          {
            "group": "Admin",
            "pages": ["api/admin/users", "api/admin/user-details"]
          },
          {
            "group": "Categories",
            "pages": ["api/categories/list", "api/categories/create", "api/categories/update", "api/categories/delete"]
